# Copy this file to `.env.production` and fill in your deployed backend.
# `npm run build` reads `.env.production` automatically (Vite production mode).
# These values are baked into the built extension folder you distribute.

# Your Render backend URL, with wss:// (NOT ws://) and the /ws path:
VITE_WS_URL=wss://your-app.onrender.com/ws

# Must exactly match AGENT_TOKEN set on the backend (Render env var):
VITE_AGENT_TOKEN=change-me-to-a-long-random-string
